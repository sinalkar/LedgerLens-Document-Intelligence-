# ───────────────────────── LLM PROVIDER ─────────────────────────
# One switch controls everything: openai | groq | ollama | openrouter
LLM_PROVIDER=openai

# Model used for vision extraction (must be a vision-capable model
# for the chosen provider — see the model matrix in README)
EXTRACTION_MODEL=gpt-4o-mini

# Optional: separate model for cheaper retries / dev
EXTRACTION_MODEL_FALLBACK=gpt-4o-mini

# ───────────────────────── PROVIDER KEYS ────────────────────────
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
# Ollama needs no key
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2-vision

# ─────────────────────── MODERATION GATE ────────────────────────
# openai  = use omni-moderation-latest (requires OPENAI_API_KEY,
#           works even when LLM_PROVIDER is groq/ollama/openrouter)
# off     = skip gate (local dev only — never in prod)
MODERATION_BACKEND=openai
MODERATION_BLOCK_THRESHOLD=0.5

# ─────────────────────── EXTRACTION TUNING ──────────────────────
REVIEW_CONFIDENCE_THRESHOLD=0.75
MAX_IMAGE_DIMENSION=2048
EXTRACTION_MAX_RETRIES=2
EXTRACTION_TEMPERATURE=0.0

# ───────────────────────── STORAGE ──────────────────────────────
# local | gcs   (Cloud Run filesystem is ephemeral → use gcs in prod)
STORAGE_BACKEND=local
UPLOAD_DIR=./uploads
DATABASE_URL=sqlite:///./ledgerlens.db
GCS_BUCKET_NAME=ledgerlens-prod-uploads
# For prod DB: postgresql+psycopg://user:pass@/db?host=/cloudsql/...

# ───────────────────────── SERVICE ──────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=INFO
ENVIRONMENT=development           # development | production
PII_REDACTION_ENABLED=true

# ───────────────────────── OBSERVABILITY ────────────────────────
METRICS_ENABLED=true
