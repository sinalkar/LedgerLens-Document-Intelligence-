{
  "title": "LedgerLens",
  "uid": "ledgerlens",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Extraction latency p50 / p95 / p99",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(extraction_latency_seconds_bucket[5m]))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(extraction_latency_seconds_bucket[5m]))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, rate(extraction_latency_seconds_bucket[5m]))", "legendFormat": "p99", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Moderation: p99 latency & blocks/hour",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.99, rate(moderation_latency_seconds_bucket[5m]))", "legendFormat": "moderation p99 (s)", "refId": "A" },
        { "expr": "rate(moderation_blocks_total[1h]) * 3600", "legendFormat": "blocks/hour", "refId": "B" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Cost per document & cumulative spend",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(token_cost_usd_total[15m]) / rate(documents_processed_total[15m])", "legendFormat": "cost per doc (USD)", "refId": "A" },
        { "expr": "token_cost_usd_total", "legendFormat": "cumulative spend (USD)", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Auto-approval rate",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "targets": [
        { "expr": "auto_approvals_total / ignoring(status) sum(documents_processed_total)", "legendFormat": "auto-approval %", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Review queue depth",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 },
      "targets": [
        { "expr": "review_queue_depth", "legendFormat": "pending items", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "min": 0 }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Throughput (docs/min by outcome)",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        { "expr": "rate(documents_processed_total[5m]) * 60", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    }
  ]
}
